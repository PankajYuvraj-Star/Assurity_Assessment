            <JSR223PostProcessor guiclass="TestBeanGUI" testclass="JSR223PostProcessor" testname="JSR223 PostProcessor" enabled="true">
              <stringProp name="cacheKey">true</stringProp>
              <stringProp name="filename"></stringProp>
              <stringProp name="parameters"></stringProp>
              <stringProp name="script">// ===== CONFIGURE OUTPUT FILE =====

def outputFile = new File(vars.get(&apos;p_OutputFile_Path&apos;) + &apos;/Categories_Promotions.csv&apos;)

// If file doesn&apos;t exist yet, create parent folders (if needed)and write the CSV header row once.
if (!outputFile.exists()) {
    outputFile.parentFile?.mkdirs()
    outputFile &lt;&lt; &quot;CategoryId,Name,Path,PromotionId,Price\n&quot;
}

def catId = vars.get(&apos;c_CategoryId&apos;)
def name = vars.get(&apos;c_Name&apos;)
def path = vars.get(&apos;c_Path&apos;)

// Number of promotions extracted (c_Promotions_Id_1..N)
def promoCountStr = vars.get(&apos;c_Promotions_Id_matchNr&apos;)
if (!promoCountStr) return  // nothing to write
int promoCount = promoCountStr as int // convert to integer

def esc = { s -&gt;
    if (s == null) return &quot;&quot;
    def str = s.toString()   // If value contains comma/quote/newline, wrap in quotes and escape quotes	
    if (str.contains(&apos;&quot;&apos;) || str.contains(&apos;,&apos;) || str.contains(&apos;\n&apos;)) {
        &apos;&quot;&apos; + str.replace(&apos;&quot;&apos;, &apos;&quot;&quot;&apos;) + &apos;&quot;&apos;
    } else {
        str
    }
}

// ===== Writes one line per promotion =====
for (int i = 1; i &lt;= promoCount; i++) {
    def promoId = vars.get(&quot;c_Promotions_Id_${i}&quot;)
    def price   = vars.get(&quot;c_Promotions_Price_${i}&quot;)
    if (promoId == null || price == null) continue

    def line = [
        esc(catId),
        esc(name),
        esc(path),
        esc(promoId),
        esc(price)
    ].join(&apos;,&apos;)

    outputFile &lt;&lt; line + &quot;\n&quot;
}</stringProp>
              <stringProp name="scriptLanguage">groovy</stringProp>
            </JSR223PostProcessor>
