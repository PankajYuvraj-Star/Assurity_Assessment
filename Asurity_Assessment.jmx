<?xml version="1.0" encoding="UTF-8"?>
<jmeterTestPlan version="1.2" properties="5.0" jmeter="5.6.3">
  <hashTree>
    <TestPlan guiclass="TestPlanGui" testclass="TestPlan" testname="Assurity_Assessment">
      <elementProp name="TestPlan.user_defined_variables" elementType="Arguments" guiclass="ArgumentsPanel" testclass="Arguments" testname="User Defined Variables">
        <collectionProp name="Arguments.arguments"/>
      </elementProp>
    </TestPlan>
    <hashTree>
      <Arguments guiclass="ArgumentsPanel" testclass="Arguments" testname="Dynamic User Defined Variables - To pass argumets using the command line while executing in the non gui mode">
        <collectionProp name="Arguments.arguments">
          <elementProp name="host" elementType="Argument">
            <stringProp name="Argument.name">host</stringProp>
            <stringProp name="Argument.value">api.tmsandbox.co.nz</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="scheme" elementType="Argument">
            <stringProp name="Argument.name">scheme</stringProp>
            <stringProp name="Argument.value">https</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="p_Threads" elementType="Argument">
            <stringProp name="Argument.name">p_Threads</stringProp>
            <stringProp name="Argument.value">${__P(p_Threads,5)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">NFR-01-Test should support Vusers (Threads) half the count of Category IDs shared in Test Data</stringProp>
          </elementProp>
          <elementProp name="p_RampUp" elementType="Argument">
            <stringProp name="Argument.name">p_RampUp</stringProp>
            <stringProp name="Argument.value">${__P(p_RampUp,5)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">NFR-02-The test should ramp up at one VUser (Thread) per second</stringProp>
          </elementProp>
          <elementProp name="p_LoopCount" elementType="Argument">
            <stringProp name="Argument.name">p_LoopCount</stringProp>
            <stringProp name="Argument.value">${__P(p_LoopCount,2)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="p_Duration" elementType="Argument">
            <stringProp name="Argument.name">p_Duration</stringProp>
            <stringProp name="Argument.value">${__P(p_Duration,60)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">NFR-03-Test should achieve 10 API calls in total for the 1-minute Steady State duration</stringProp>
          </elementProp>
          <elementProp name="p_StartUpDelay" elementType="Argument">
            <stringProp name="Argument.name">p_StartUpDelay</stringProp>
            <stringProp name="Argument.value">${__P(p_StartUpDelay,0)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
          <elementProp name="p_TargetThroughput" elementType="Argument">
            <stringProp name="Argument.name">p_TargetThroughput</stringProp>
            <stringProp name="Argument.value">${__P(p_TargetThroughput,10)}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">NFR-03-Test should achieve 10 API calls in total for the 1-minute Steady State duration</stringProp>
          </elementProp>
          <elementProp name="p_CategoryID_CSV_Path" elementType="Argument">
            <stringProp name="Argument.name">p_CategoryID_CSV_Path</stringProp>
            <stringProp name="Argument.value">C:/{PathtotheCSVFile}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Update the path to the CSV file for Category  the path format is &quot;/&quot;</stringProp>
          </elementProp>
          <elementProp name="p_CategoryID_Random_CSV_Path" elementType="Argument">
            <stringProp name="Argument.name">p_CategoryID_Random_CSV_Path</stringProp>
            <stringProp name="Argument.value">C:\{PathtotheCSVFile}</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
            <stringProp name="Argument.desc">Update the path to the CSV file for Randon Category ID the path format is different &quot;\&quot;</stringProp>
          </elementProp>
          <elementProp name="p_OutputFile_Path" elementType="Argument">
            <stringProp name="Argument.name">p_OutputFile_Path</stringProp>
            <stringProp name="Argument.value">C:/{PathForOutputfile}</stringProp>
            <stringProp name="Argument.desc">Update the path to save the output file the path format is &quot;/&quot;</stringProp>
            <stringProp name="Argument.metadata">=</stringProp>
          </elementProp>
        </collectionProp>
        <stringProp name="TestPlan.comments">If no values are passed during run time the script will default to predefined values which will ahieve the desired throughput for this assessment- This approach reusability, easy to use in the pipelines.</stringProp>
      </Arguments>
